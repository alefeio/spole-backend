## API
PORT=3000
NODE_ENV=development

## PostgreSQL (docker-compose)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=spole
POSTGRES_PASSWORD=spole
POSTGRES_DB=spole

## Redis (docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

## Bookings (TTL em segundos; padrão 1800 = 30 min)
BOOKING_TTL_SECONDS=1800

## Reservas de arena — pagamento inicial (TTL em segundos; padrão 1800 = 30 min)
RESERVATION_TTL_SECONDS=1800

## Pagamentos (webhook sem JWT; header X-Spole-Payment-Webhook-Secret)
PAYMENTS_WEBHOOK_SECRET=change-me-webhook-secret

## Cache de leitura pública (GET /events, GET /categories; segundos; padrão 60)
PUBLIC_READ_CACHE_TTL_SECONDS=60

## Rate limiting (janela em segundos / máximo por janela)
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX_REQUESTS=20
RATE_LIMIT_PUBLIC_READ_WINDOW_SECONDS=60
RATE_LIMIT_PUBLIC_READ_MAX_REQUESTS=120
RATE_LIMIT_AUTHENTICATED_WINDOW_SECONDS=60
RATE_LIMIT_AUTHENTICATED_MAX_REQUESTS=60
RATE_LIMIT_WEBHOOK_WINDOW_SECONDS=60
RATE_LIMIT_WEBHOOK_MAX_REQUESTS=1000

## Idempotência de cliente (TTL dos registros em segundos; padrão 86400 = 24h)
IDEMPOTENCY_TTL_SECONDS=86400

## JWT
JWT_SECRET=change-me-in-prod
JWT_ISSUER=spole-api
JWT_AUDIENCE=spole-clients
JWT_EXPIRES_IN=7d
